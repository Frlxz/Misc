local WindUI = loadstring(game:HttpGet("https://github.com/Footagesus/WindUI/releases/latest/download/main.lua"))()
local NotificationHolder = loadstring(game:HttpGet("https://raw.githubusercontent.com/Nadir3709/Notification/main/NotificationHolder"))()
local Notification = loadstring(game:HttpGet("https://raw.githubusercontent.com/Nadir3709/Notification/main/Notification"))()

local function Notify(title, text, time)
    Notification:Notify(
        { Title = title, Description = text },
        { OutlineColor = Color3.fromRGB(100, 100, 100), Time = time or 5, Type = "default" }
    )
end

local link = "https://discord.gg/Nvhb3EnMDX"

WindUI:Popup({
    Title = "Funky Friday Update",
    Icon = "info",
    Content = "⚠️ The script is temporarily unusable.\n\nThe script is currently being updated\ndue to a recent Funky Friday game update.\n\nJoin our Discord to get the latest info:\n" .. link,
    Buttons = {
        {
            Title = "Continue",
            Icon = "arrow-right",
            Callback = function()
                if setclipboard then
                    setclipboard(link)
                    Notify("Copied!", "Discord invite copied to clipboard.", 5)
                else
                    Notify("Clipboard Unsupported", "Executor doesn't support setclipboard.", 5)
                end
            end,
            Variant = "Primary",
        }
    }
})
